<Window x:Class="DigitalCoreAnalyser.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистический анализ образцов">
    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock x:Name="StatusText"
                       Text="Статистический анализ"
                       FontSize="20"
                       Foreground="#2C3E50"
                       Margin="0,0,0,20"/>

            <ProgressBar x:Name="ProgressBar"
                         IsIndeterminate="True"
                         Width="300"
                         Height="20"
                         Margin="0,0,0,20"
                         Foreground="#3498DB"
                         Background="#E8EEF2"/>

            <!-- Область для графика с Image -->
            <Border x:Name="ChartArea"
                    Width="1300"
                    Height="500"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Background="White"
                    Margin="0,0,0,20">
                <Grid>
                    <Image x:Name="ChartImage"
                           Stretch="Uniform"
                           Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Навигация -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,10">
                <Button x:Name="PrevButton"
                        Content="◄ Назад"
                        Width="100"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Margin="0,0,10,0"
                        IsEnabled="False"
                        Click="OnPrevClick"/>
                <Border Background="#4a90e2"
                        CornerRadius="4"
                        Padding="10,0,10,0"
                        Height="36"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="PageInfo"
                               Text="1/8"
                               FontSize="14"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
                <Button x:Name="NextButton"
                        Content="Вперед ►"
                        Width="100"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Margin="10,0,0,0"
                        IsEnabled="False"
                        Click="OnNextClick"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="10">
                <Button x:Name="AnalyzeButtonPorosity"
                        Content="Анализировать пористость"
                        Width="240"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnAnalyzeClickPorosity"/>

                <Button x:Name="AnalyzeButtonPermeability"
                        Content="Анализировать проницаемость"
                        Width="240"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnAnalyzeClickPermeability"/>

                <Button x:Name="SaveButton"
                        Content="Сохранить"
                        Width="120"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnSaveClick"/>

                <Button x:Name="ExportButton"
                        Content="Экспорт CSV"
                        Width="120"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnExportClick"/>

                <Button x:Name="ClearButton"
                        Content="Очистить"
                        Width="120"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnClearClick"/>

                <Button x:Name="CloseButton"
                        Content="Закрыть"
                        Width="120"
                        Height="36"
                        Background="#4a90e2"
                        Foreground="White"
                        Click="OnCloseClick"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>